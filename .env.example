# Convex Configuration
VITE_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOYMENT=your-deployment-name

# Backend-only secrets (DO NOT prefix with VITE_)
# These should be set in Convex Dashboard or Vercel Environment Variables
SHEETS_WEBAPP_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
SHEETS_SECRET=your_secret_here

# NabooPay Payment Gateway (set in Convex Dashboard)
NABOOPAY_TOKEN=your_naboopay_api_token
NABOOPAY_WEBHOOK_SECRET=your_naboopay_webhook_secret
# NabooPay webhook URL to register in NabooPay dashboard:
# https://your-deployment-name.convex.site/naboopay-webhook
