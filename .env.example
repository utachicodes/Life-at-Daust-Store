# Convex Configuration
VITE_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOYMENT=your-deployment-name

# Backend-only secrets (set these in the Convex Dashboard under Settings > Environment Variables)
# NabooPay Payment Gateway
NABOOPAY_TOKEN=your_naboopay_api_token
NABOOPAY_WEBHOOK_SECRET=your_naboopay_webhook_secret
# NabooPay webhook URL to register in NabooPay dashboard:
# https://shop.daustgov.com/naboopay-webhook

# Resend (email service for password reset)
# Sign up at https://resend.com and verify the domain shop.daustgov.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
